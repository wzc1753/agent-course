# =============================================================================
# API Keys
# =============================================================================

# OpenAI API Key (for GPT models and embeddings)
OPENAI_API_KEY=sk-...

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=sk-ant-...

# Google API Key (for Gemini models)
GOOGLE_API_KEY=...

# Serper API Key (for Google search)
SERPER_API_KEY=...

# Tavily API Key (for AI-powered search)
TAVILY_API_KEY=tvly-...


# =============================================================================
# LLM Model Settings
# =============================================================================

# LLM Provider: anthropic, openai, or google
LLM_PROVIDER=anthropic

# Model name (e.g., claude-sonnet-4-6, gpt-4, gemini-pro)
LLM_MODEL=claude-sonnet-4-6

# Temperature for LLM responses (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.0

# Maximum tokens for LLM responses
LLM_MAX_TOKENS=4096

# Request timeout in seconds
LLM_TIMEOUT=120


# =============================================================================
# Match Score Thresholds
# =============================================================================

# High confidence match threshold (0.85 = 85% match)
MATCH_THRESHOLD_HIGH=0.85

# Medium confidence match threshold
MATCH_THRESHOLD_MEDIUM=0.65

# Low confidence match threshold
MATCH_THRESHOLD_LOW=0.45


# =============================================================================
# Verification Settings
# =============================================================================

# Maximum number of claims to verify in a single run
MAX_CLAIMS_TO_VERIFY=50

# Maximum sources to fetch per claim
MAX_SOURCES_PER_CLAIM=5

# Minimum confidence score for sources
MIN_SOURCE_CONFIDENCE=0.5

# Enable parallel verification (true/false)
ENABLE_PARALLEL_VERIFICATION=true

# Maximum worker threads for parallel processing
MAX_WORKERS=5


# =============================================================================
# Rate Limits
# =============================================================================

# Maximum API requests per minute
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Maximum tokens per minute
RATE_LIMIT_TOKENS_PER_MINUTE=80000

# Number of retry attempts on rate limit
RATE_LIMIT_RETRY_ATTEMPTS=3

# Delay between retries in seconds
RATE_LIMIT_RETRY_DELAY=5


# =============================================================================
# Search Settings
# =============================================================================

# Maximum search results to retrieve
SEARCH_MAX_RESULTS=10

# Search request timeout in seconds
SEARCH_TIMEOUT=30

# Number of retry attempts for failed searches
SEARCH_RETRY_ATTEMPTS=2


# =============================================================================
# Cache Settings
# =============================================================================

# Enable caching (true/false)
ENABLE_CACHE=true

# Cache backend: file, memory, redis
CACHE_BACKEND=file

# Cache directory path
CACHE_DIR=.cache

# Cache TTL in seconds (86400 = 24 hours)
CACHE_TTL_SECONDS=86400

# Maximum cache size in MB
CACHE_MAX_SIZE_MB=500


# =============================================================================
# Embedding Settings
# =============================================================================

# Embedding model (e.g., text-embedding-3-small, text-embedding-ada-002)
EMBEDDING_MODEL=text-embedding-3-small

# Embedding dimension
EMBEDDING_DIMENSION=1536

# Batch size for embedding generation
EMBEDDING_BATCH_SIZE=100


# =============================================================================
# Output Settings
# =============================================================================

# Output directory path
OUTPUT_DIR=output

# Output format: json, csv, excel
OUTPUT_FORMAT=json

# Save intermediate results (true/false)
SAVE_INTERMEDIATE_RESULTS=true

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO


# =============================================================================
# System Settings
# =============================================================================

# Enable debug mode (true/false)
DEBUG_MODE=false

# Enable verbose output (true/false)
VERBOSE=false

# Random seed for reproducibility (leave empty for random)
RANDOM_SEED=
