# PaperGuard Agent - 环境变量配置

# ==========================================
# LLM API配置 (Full模式的论断验证需要)
# ==========================================

# MiniMax-M3 API (推荐，国内可用)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here

# OpenAI API (备用)
# 如果没有配置MiniMax，会自动使用OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# ==========================================
# 学术数据库API (可选，提高验证准确率)
# ==========================================

# Crossref API (推荐配置email以提高请求优先级)
CROSSREF_EMAIL=your_email@example.com

# Semantic Scholar API (可选，有Key可提高限流)
SEMANTIC_SCHOLAR_API_KEY=your_s2_api_key_here

# OpenAlex API (可选，有Email可提高限流)
OPENALEX_EMAIL=your_email@example.com
